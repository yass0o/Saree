<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_item_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:strokeColor="@color/gray_200"
    app:strokeWidth="0.5dp"
    app:cardUseCompatPadding="true"
    app:cardPreventCornerOverlap="false">

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Metadata Row -->
        <LinearLayout
            android:id="@+id/metadata_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="10dp"
            android:baselineAligned="false"
            android:weightSum="3">

            <TextView
                android:id="@+id/source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTintMode="src_atop"
                android:background="@drawable/chip_background"
                android:fontFamily="@font/tajawal_medium"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="المصدر"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_background_alt"
                android:fontFamily="@font/tajawal_medium"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="الفئة"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/displayDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_background_date"
                android:fontFamily="@font/tajawal_medium"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="التاريخ"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Image -->
        <ImageView
            android:id="@+id/bayan_image"
            android:layout_width="300dp"
            android:scaleType="fitXY"
            android:layout_gravity="center"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
