<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/do3a2_background"
    tools:context=".Activities.MainActivity">

    <TextView
        android:id="@+id/main_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:padding="5dp"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/tajawal_medium"
        android:layout_alignParentEnd="true"
        android:textStyle="bold"
        android:textColor="@color/dark_orange"
        android:shadowColor="@color/orange"
        android:shadowDx="-2"
        android:shadowDy="2"
        android:shadowRadius="1"
        android:text="بيانات المقاومة"
        android:textSize="24sp" />
    <LinearLayout
        android:id="@+id/action_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignTop="@+id/main_title"
        android:layout_alignBottom="@+id/main_title"
        android:gravity="center"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_alignParentStart="true"
        android:background="@drawable/rounded_orange_border"
        android:padding="5dp">

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/rb_full"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كامل" />

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/rb_formatted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="معدل" />
        </RadioGroup>
    </LinearLayout>

    <!--    app:drawableEndCompat="@drawable/alsarea_trans"-->
    <!--    app:drawableTint="@color/dark_orange"-->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_above="@+id/main_search"
        android:layout_margin="16dp"
        app:fabSize="mini"
        android:visibility="gone"
        app:srcCompat="@drawable/ic_up"
        app:backgroundTint="@color/purple_200" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/pullToRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/main_title">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbarThumbVertical="@color/orange"
                android:scrollbarSize="5dp"
                android:layout_marginEnd="5dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:scrollbars="vertical" />
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminateDrawable="@drawable/saree_anim"
                android:visibility="gone"/>
        </RelativeLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <EditText
        android:id="@+id/main_search"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:visibility="gone"
        android:layout_alignParentBottom="true"
        android:textColor="@color/white"
        android:background="@color/orange_800"
        android:fontFamily="@font/tajawal_medium"
        android:drawableStart="@drawable/ic_search"
        android:drawableTint="@color/white"
        android:textColorHint="@android:color/white"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        android:textSize="15sp"
        android:gravity="start|center_vertical"
        android:lines="1"
        android:hint="بحث"
        android:imeOptions="actionSearch" />

</RelativeLayout>